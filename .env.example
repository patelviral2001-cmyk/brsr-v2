# Copy to .env and fill in. Used by docker-compose.prod.yml.

# === Public domain ===
# When set, Caddy obtains a Let's Encrypt cert. Leave blank for HTTP-only dev.
DOMAIN=

# === Postgres ===
POSTGRES_USER=brsr
POSTGRES_PASSWORD=changeme-strong-pw
POSTGRES_DB=brsr
DATABASE_URL=postgresql://brsr:changeme-strong-pw@postgres:5432/brsr

# === Redis ===
REDIS_URL=redis://redis:6379

# === MinIO (S3-compatible) ===
S3_ACCESS_KEY=brsr-admin
S3_SECRET_KEY=changeme-minio-pw
# (S3_ENDPOINT is hardcoded in compose to http://minio:9000)

# === Secrets ===
# 32+ char random strings, distinct per environment
JWT_SECRET=please-generate-with-openssl-rand-hex-32
INTERNAL_CALLBACK_SECRET=please-generate-with-openssl-rand-hex-32

# === OpenAI ===
# Get from https://platform.openai.com/api-keys
# Required for: document classification (gpt-5-nano), LLM extraction fallback (gpt-5),
# copilot. The rule-based extractors handle 99%+ of electricity bills without this.
OPENAI_API_KEY=sk-proj-...

# === CORS ===
# Comma-separated origins for the API. Leave blank in production (Caddy enforces).
CORS_ORIGIN=

# === Optional: Keycloak (not used in current deploy) ===
KEYCLOAK_URL=
KEYCLOAK_REALM=brsr
KEYCLOAK_CLIENT_ID=brsr-api
KEYCLOAK_CLIENT_SECRET=

# === Optional: OPA ABAC (disabled in current deploy) ===
OPA_URL=
OPA_ENABLED=false

# === Optional: migrations on boot ===
RUN_MIGRATIONS=true
