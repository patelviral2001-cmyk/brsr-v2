{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "plugins": ["prettier-plugin-prisma"],
  "overrides": [
    {
      "files": "*.prisma",
      "options": { "tabWidth": 2 }
    },
    {
      "files": ["*.md", "*.mdx"],
      "options": { "proseWrap": "preserve" }
    }
  ]
}
