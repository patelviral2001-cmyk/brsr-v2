# ============================================================
# BRSR AI Platform v2 - API Gateway environment example
# ============================================================

NODE_ENV="development"
PORT=4000
LOG_LEVEL="debug"

# Database
DATABASE_URL="postgresql://brsr:brsr@localhost:5432/brsr_dev?schema=public"
DATABASE_URL_DIRECT="postgresql://brsr:brsr@localhost:5432/brsr_dev?schema=public"

# Redis / BullMQ
REDIS_URL="redis://localhost:6379"

# Object storage (S3 / MinIO)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="brsr-dev"
S3_BUCKET_EVIDENCE="brsr-evidence"
S3_BUCKET_REPORTS="brsr-reports"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_FORCE_PATH_STYLE=true

# Search / vector
OPENSEARCH_URL="http://localhost:9200"
QDRANT_URL="http://localhost:6333"

# Streaming
KAFKA_BROKERS="localhost:9092"

# Keycloak
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="brsr"
KEYCLOAK_CLIENT_ID="brsr-api"
KEYCLOAK_CLIENT_SECRET="change-me"
KEYCLOAK_ADMIN_USER="admin"
KEYCLOAK_ADMIN_PASSWORD="admin"

# JWT verification
JWT_PUBLIC_KEY=""
JWT_ISSUER="http://localhost:8080/realms/brsr"
JWT_AUDIENCE="brsr-api"

# Internal AI services
AI_ENGINE_URL="http://localhost:8100"
COPILOT_URL="http://localhost:8101"
INTERNAL_CALLBACK_SECRET="please-change-this-shared-secret"

# OPA - Open Policy Agent
OPA_URL="http://localhost:8181"
OPA_ENABLED=true

# Observability
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="brsr-api"

# Workflow (Temporal)
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="brsr"

# Email (Postmark)
POSTMARK_TOKEN="changeme"
EMAIL_FROM="no-reply@brsr.example.com"

# Magic-link signing
MAGIC_LINK_SECRET="change-me-magic"
PUBLIC_BASE_URL="http://localhost:3000"
