// THE ESG — AI Native Sustainability Operating System
// Final schema (Phase 0). Drops the legacy BRSR Platform schema entirely.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────
// IDENTITY & TENANCY
// ────────────────────────────────────────────────────────────────

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  brandColor    String?  @map("brand_color")
  dataResidency String   @default("IN") @map("data_residency")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  users             User[]
  roles             Role[]
  reportingEntities ReportingEntity[]
  sites             Site[]
  evidence          Evidence[]
  dataPoints        DataPoint[]
  kpiCalculations   KpiCalculation[]
  reports           Report[]
  auditTrail        AuditTrail[]

  @@map("tenant")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  idpSubject   String    @unique @map("idp_subject")
  email        String
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  passwordHash String?   @map("password_hash")
  locale       String    @default("en-IN")
  timezone     String    @default("Asia/Kolkata")
  mfaEnrolled  Boolean   @default(false) @map("mfa_enrolled")
  lastLoginAt  DateTime? @map("last_login_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleAssignments RoleAssignment[]

  @@unique([tenantId, email])
  @@map("user")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions String[]

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments RoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("role")
}

model RoleAssignment {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  roleId    String    @map("role_id")
  grantedBy String    @map("granted_by")
  grantedAt DateTime  @default(now()) @map("granted_at")
  expiresAt DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@index([expiresAt])
  @@map("role_assignment")
}

// ────────────────────────────────────────────────────────────────
// PHYSICAL — Reporting Entity + Site
// ────────────────────────────────────────────────────────────────

model ReportingEntity {
  id                      String   @id @default(cuid())
  tenantId                String   @map("tenant_id")
  name                    String
  cinOrLlpin              String?  @map("cin_or_llpin")
  pan                     String?
  gstin                   String?
  parentReportingEntityId String?  @map("parent_reporting_entity_id")
  listed                  Boolean  @default(false)
  fyStartMonth            Int      @default(4) @map("fy_start_month")
  reportingCurrency       String   @default("INR") @map("reporting_currency")
  createdAt               DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sites      Site[]
  dataPoints DataPoint[]

  @@unique([tenantId, cinOrLlpin])
  @@index([tenantId])
  @@map("reporting_entity")
}

model Site {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  reportingEntityId String?  @map("reporting_entity_id")

  name              String
  externalCode      String?  @map("external_code")
  siteType          String   @map("site_type")

  addressLine1      String?  @map("address_line1")
  addressLine2      String?  @map("address_line2")
  city              String?
  district          String?
  state             String?
  pincode           String?
  country           String   @default("IN")
  latitude          Decimal? @db.Decimal(10, 7)
  longitude         Decimal? @db.Decimal(10, 7)

  commissionedAt    DateTime? @map("commissioned_at")   @db.Date
  decommissionedAt  DateTime? @map("decommissioned_at") @db.Date
  areaSqm           Decimal?  @map("area_sqm")

  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportingEntity ReportingEntity? @relation(fields: [reportingEntityId], references: [id], onDelete: SetNull)
  evidence        Evidence[]
  dataPoints      DataPoint[]

  @@unique([tenantId, externalCode])
  @@index([tenantId, status])
  @@map("site")
}

// ────────────────────────────────────────────────────────────────
// EVIDENCE — documents only. Source of truth lives in DataPoint.
// ────────────────────────────────────────────────────────────────

model Evidence {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  siteId       String?  @map("site_id")

  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  sizeBytes    BigInt   @map("size_bytes")
  sha256       String
  s3Bucket     String   @map("s3_bucket")
  s3Key        String   @map("s3_key")

  docType      String   @map("doc_type")
  pageCount    Int?     @map("page_count")
  language     String?
  ocrApplied   Boolean  @default(false) @map("ocr_applied")

  hintPeriodStart DateTime? @map("hint_period_start") @db.Date
  hintPeriodEnd   DateTime? @map("hint_period_end")   @db.Date

  uploadedBy   String   @map("uploaded_by")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  status               String  @default("PENDING")
  classifierConfidence Float?  @map("classifier_confidence")
  failureReason        String? @map("failure_reason") @db.Text

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site        Site?              @relation(fields: [siteId], references: [id], onDelete: SetNull)
  extractions ExtractionResult[]
  dataPoints  DataPoint[]

  @@unique([tenantId, sha256])
  @@index([tenantId, status, uploadedAt(sort: Desc)])
  @@index([tenantId, docType])
  @@map("evidence")
}

model ExtractionResult {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  evidenceId String   @map("evidence_id")

  schemaCode String   @map("schema_code")
  payload    Json
  confidence Float

  rawText    String?  @db.Text

  status     String   @default("DRAFT")
  reviewedBy String?  @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([evidenceId])
  @@map("extraction_result")
}

// ────────────────────────────────────────────────────────────────
// ONTOLOGY — ESG Topics, KPIs, Standards, Disclosures
// ────────────────────────────────────────────────────────────────

model EsgTopic {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String?  @db.Text
  pillar      String
  sortKey     Int      @default(0) @map("sort_key")

  kpis Kpi[]

  @@map("esg_topic")
}

model Kpi {
  id                  String   @id @default(cuid())
  code                String   @unique
  title               String
  description         String?  @db.Text
  topicId             String   @map("topic_id")

  payloadKind         String   @map("payload_kind")
  unit                String?

  materializationKind String   @map("materialization_kind")
  aggregation         String?
  formula             Json?

  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")

  topic        EsgTopic         @relation(fields: [topicId], references: [id])
  dataPoints   DataPoint[]
  calculations KpiCalculation[]
  disclosures  Disclosure[]

  @@index([topicId])
  @@map("kpi")
}

model Standard {
  id      String  @id @default(cuid())
  code    String  @unique
  title   String
  version String
  active  Boolean @default(true)

  disclosures Disclosure[]

  @@map("standard")
}

model Disclosure {
  id           String  @id @default(cuid())
  standardId   String  @map("standard_id")
  code         String
  section      String?
  questionText String  @map("question_text") @db.Text
  kpiId        String? @map("kpi_id")
  notes        String? @db.Text

  standard Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)
  kpi      Kpi?     @relation(fields: [kpiId], references: [id])

  @@unique([standardId, code])
  @@map("disclosure")
}

// ────────────────────────────────────────────────────────────────
// DATA POINTS — THE source of truth for ESG data
// ────────────────────────────────────────────────────────────────

model DataPoint {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  kpiId              String   @map("kpi_id")

  siteId             String?  @map("site_id")
  reportingEntityId  String?  @map("reporting_entity_id")

  periodStart        DateTime @map("period_start") @db.Date
  periodEnd          DateTime @map("period_end")   @db.Date
  fy                 String

  payload            Json

  source             String
  evidenceId         String?  @map("evidence_id")
  extractionResultId String?  @map("extraction_result_id")
  confidenceScore    Float?   @map("confidence_score")

  status             String   @default("CONFIRMED")
  submittedBy        String   @map("submitted_by")
  submittedAt        DateTime @default(now()) @map("submitted_at")
  lockedBy           String?  @map("locked_by")
  lockedAt           DateTime? @map("locked_at")
  deletedAt          DateTime? @map("deleted_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kpi             Kpi              @relation(fields: [kpiId], references: [id])
  site            Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  reportingEntity ReportingEntity? @relation(fields: [reportingEntityId], references: [id], onDelete: SetNull)
  evidence        Evidence?        @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, kpiId, siteId, reportingEntityId, periodStart], name: "data_point_unique_scope_period")
  @@index([tenantId, fy, kpiId])
  @@index([siteId, periodStart])
  @@index([evidenceId])
  @@map("data_point")
}

model KpiCalculation {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  kpiId               String   @map("kpi_id")

  siteId              String?  @map("site_id")
  fy                  String
  periodStart         DateTime @map("period_start") @db.Date
  periodEnd           DateTime @map("period_end")   @db.Date

  payload             Json

  inputDataPointIds   String[] @map("input_data_point_ids")
  inputCalculationIds String[] @map("input_calculation_ids")

  status              String   @default("VALID")
  computedAt          DateTime @default(now()) @map("computed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kpi    Kpi    @relation(fields: [kpiId], references: [id])

  @@unique([tenantId, kpiId, siteId, periodStart, periodEnd])
  @@index([tenantId, fy])
  @@index([status])
  @@map("kpi_calculation")
}

// ────────────────────────────────────────────────────────────────
// REPORTS
// ────────────────────────────────────────────────────────────────

model Report {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  standardCode String   @map("standard_code")
  fy           String
  title        String
  status       String   @default("DRAFT")
  pdfS3        String?  @map("pdf_s3")
  xlsxS3       String?  @map("xlsx_s3")
  generatedBy  String   @map("generated_by")
  generatedAt  DateTime @default(now()) @map("generated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, standardCode, fy])
  @@map("report")
}

// ────────────────────────────────────────────────────────────────
// AUDIT TRAIL
// ────────────────────────────────────────────────────────────────

model AuditTrail {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  diff        Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  requestId   String?  @map("request_id")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_trail")
}
