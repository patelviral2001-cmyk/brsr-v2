PORT=8100
LOG_LEVEL=INFO
ENV=production
SERVICE_NAME=ai-engine

# ---------------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------------
# OPENAI_API_KEY is the only REQUIRED key for production. The engine routes
# every LLM call through OpenAI's chat/completions and embeddings endpoints.
OPENAI_API_KEY=

# Anthropic is OPTIONAL — kept only as a manual emergency fallback that can be
# enabled by setting ENABLE_ANTHROPIC_FALLBACK=true. Production deployments
# normally leave it blank.
ANTHROPIC_API_KEY=
ENABLE_ANTHROPIC_FALLBACK=false

# Optional — only used by Vertex / Gemini fallback paths.
GOOGLE_API_KEY=

# Optional OpenAI-compatible proxy (e.g. LiteLLM Gateway, Azure OpenAI, Helicone).
# Leave blank to talk to api.openai.com directly.
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# ---------------------------------------------------------------------------
# Model selection (per task)
# Override these without touching code; they feed into model_router_config.
# ---------------------------------------------------------------------------
OPENAI_MODEL_CLASSIFIER=gpt-5-nano
OPENAI_MODEL_EXTRACTOR=gpt-5
OPENAI_MODEL_VALIDATOR=gpt-5
OPENAI_MODEL_NARRATIVE=gpt-5
OPENAI_MODEL_EMBEDDING=text-embedding-3-large

# Hard fallback tier (used when primary returns persistent errors).
OPENAI_MODEL_CLASSIFIER_FALLBACK=gpt-4o-mini
OPENAI_MODEL_EXTRACTOR_FALLBACK=gpt-4o
OPENAI_MODEL_VALIDATOR_FALLBACK=gpt-4o
OPENAI_MODEL_NARRATIVE_FALLBACK=gpt-4o
OPENAI_MODEL_EMBEDDING_FALLBACK=text-embedding-3-small

# Per-call timeout (seconds) for any OpenAI request. Long PDFs may legitimately
# take >60s when many extract_entity calls run in parallel.
EXTRACTION_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Backend integration
# ---------------------------------------------------------------------------
BACKEND_URL=http://localhost:4000
BACKEND_CALLBACK_SECRET=change-me

# ---------------------------------------------------------------------------
# Object storage
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Vector store
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------------------------------------------------------------------------
# Queue
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# OCR backends
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
USE_TEXTRACT=false
USE_AZURE_DOC_INTEL=false

# ---------------------------------------------------------------------------
# Embeddings (legacy aliases — kept for backward compat with config.py)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL_PRIMARY=text-embedding-3-large
EMBEDDING_MODEL_FALLBACK=BAAI/bge-large-en-v1.5

# ---------------------------------------------------------------------------
# Routing thresholds
# ---------------------------------------------------------------------------
CONFIDENCE_REVIEW_THRESHOLD=0.65
CONFIDENCE_HIGH_THRESHOLD=0.85
