# Copilot service runtime configuration. Copy to .env and edit.

# ---- HTTP
PORT=8101
HOST=0.0.0.0
LOG_LEVEL=info
ENV=development

# ---- LLM providers
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-openai-replace-me

# Models
ANTHROPIC_PRIMARY_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_FAST_MODEL=claude-3-5-haiku-20241022
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ---- Internal services
BACKEND_URL=http://localhost:4000
BACKEND_INTERNAL_TOKEN=replace-with-shared-secret-from-backend

# ---- Vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Cache
REDIS_URL=redis://localhost:6379/2

# ---- Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Auth
JWT_PUBLIC_KEY_PEM_PATH=/run/secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ISSUER=brsr-v2-api

# ---- Limits
MAX_TOKENS_PER_RESPONSE=4096
MAX_TOOL_CALLS_PER_TURN=12
REQUEST_TIMEOUT_SECONDS=120
