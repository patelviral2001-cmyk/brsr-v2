environment        = "prod"
aws_region         = "ap-south-1"
aws_region_dr      = "ap-south-2"
cost_center        = "ENG-PLATFORM"

# Networking
vpc_cidr           = "10.40.0.0/16"
public_subnets     = ["10.40.0.0/22",  "10.40.4.0/22",  "10.40.8.0/22"]
private_subnets    = ["10.40.16.0/20", "10.40.32.0/20", "10.40.48.0/20"]
database_subnets   = ["10.40.64.0/22", "10.40.68.0/22", "10.40.72.0/22"]

# Aurora
db_instance_class  = "db.r7g.xlarge"
db_reader_count    = 2

# Redis
redis_node_type    = "cache.r7g.large"

# ACM (issue in advance)
acm_certificate_arn = "arn:aws:acm:ap-south-1:111111111111:certificate/REPLACE_ME"
cloudfront_acm_arn  = "arn:aws:acm:us-east-1:111111111111:certificate/REPLACE_ME"

cloudfront_domains  = ["app.brsrai.com", "supplier.brsrai.com", "api.brsrai.com"]

# PrivateLink (allowed customer accounts that consume our ERP-sync endpoint)
privatelink_allowed_principals = [
  # "arn:aws:iam::222222222222:root", # AcmeSteel
]
