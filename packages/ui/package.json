{
  "name": "@brsr/ui",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Shared React component library for the BRSR AI Platform — used by apps/web and apps/supplier-portal.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./tailwind-preset": "./tailwind.config.ts"
  },
  "files": [
    "src",
    "tailwind.config.ts",
    "postcss.config.cjs",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@brsr/contracts": "workspace:*",
    "@brsr/shared": "workspace:*",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.395.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  },
  "sideEffects": [
    "**/*.css"
  ]
