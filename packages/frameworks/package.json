{
  "name": "@brsr/frameworks",
  "version": "0.1.0",
  "description": "Canonical ESG metric registry and multi-framework crosswalks (BRSR, BRSR Core, GRI, SASB, TCFD, IFRS S1/S2, CSRD/ESRS, CDP).",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./canonical": {
      "types": "./dist/canonical/metrics.d.ts",
      "import": "./dist/canonical/metrics.js"
    },
    "./brsr": {
      "types": "./dist/frameworks/brsr.d.ts",
      "import": "./dist/frameworks/brsr.js"
    },
    "./gri": {
      "types": "./dist/frameworks/gri.d.ts",
      "import": "./dist/frameworks/gri.js"
    },
    "./sasb": {
      "types": "./dist/frameworks/sasb.d.ts",
      "import": "./dist/frameworks/sasb.js"
    },
    "./tcfd": {
      "types": "./dist/frameworks/tcfd.d.ts",
      "import": "./dist/frameworks/tcfd.js"
    },
    "./ifrs": {
      "types": "./dist/frameworks/ifrs.d.ts",
      "import": "./dist/frameworks/ifrs.js"
    },
    "./csrd-esrs": {
      "types": "./dist/frameworks/csrd-esrs.d.ts",
      "import": "./dist/frameworks/csrd-esrs.js"
    },
    "./cdp": {
      "types": "./dist/frameworks/cdp.d.ts",
      "import": "./dist/frameworks/cdp.js"
    },
    "./crosswalks": {
      "types": "./dist/crosswalks/index.d.ts",
      "import": "./dist/crosswalks/index.js"
    },
    "./factors/cea": {
      "types": "./dist/factors/cea-india.d.ts",
      "import": "./dist/factors/cea-india.js"
    },
    "./factors/defra": {
      "types": "./dist/factors/defra.d.ts",
      "import": "./dist/factors/defra.js"
    },
    "./factors/gwp": {
      "types": "./dist/factors/ipcc-gwp.d.ts",
      "import": "./dist/factors/ipcc-gwp.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
