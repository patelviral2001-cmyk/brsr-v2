{
  "name": "@brsr/shared",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./units": {
      "types": "./dist/units.d.ts",
      "development": "./src/units.ts",
      "default": "./dist/units.js"
    },
    "./gwp": {
      "types": "./dist/gwp.d.ts",
      "development": "./src/gwp.ts",
      "default": "./dist/gwp.js"
    },
    "./dates": {
      "types": "./dist/dates.d.ts",
      "development": "./src/dates.ts",
      "default": "./dist/dates.js"
    },
    "./confidence": {
      "types": "./dist/confidence.d.ts",
      "development": "./src/confidence.ts",
      "default": "./dist/confidence.js"
    },
    "./ltree": {
      "types": "./dist/ltree.d.ts",
      "development": "./src/ltree.ts",
      "default": "./dist/ltree.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "development": "./src/errors.ts",
      "default": "./dist/errors.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "development": "./src/result.ts",
      "default": "./dist/result.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "vitest": "^1.6.0"
  }
}
