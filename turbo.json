{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env",
    "**/.env.*",
    "tsconfig.base.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_BUCKET",
    "OPENSEARCH_URL",
    "QDRANT_URL",
    "KAFKA_BROKERS",
    "KEYCLOAK_URL",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "LANGFUSE_PUBLIC_KEY",
    "LANGFUSE_SECRET_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "generated/**"],
      "inputs": [
        "src/**",
        "prisma/**",
        "tsconfig.json",
        "package.json",
        "next.config.*",
        "tailwind.config.*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", ".eslintrc.*", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "vitest.config.*", "jest.config.*"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "prisma:generate": {
      "outputs": ["node_modules/.prisma/**", "src/generated/**"],
      "inputs": ["prisma/schema.prisma"]
    },
    "prisma:migrate": {
      "cache": false,
      "dependsOn": ["prisma:generate"]
    },
    "prisma:seed": {
      "cache": false,
      "dependsOn": ["prisma:migrate"]
    }
  }
}
